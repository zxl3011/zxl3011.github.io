---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
// import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SOCIALS } from "@/constants";
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Xinlu Zhang
      </h1>

      <!--  链接blog
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>
      -->
      <p>Graduate Software Developer based in Australia</p>
      <p>
        I build full-stack and backend applications with Java Spring Boot,
  REST APIs, relational databases, and cloud deployment.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="featured-projects" class="pt-12 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide">Featured Projects</h2>
      <ul class="mt-4 space-y-6">
        <li class="border border-border rounded-lg p-4">
          <h3 class="text-lg font-semibold">Surfboard Rental Management System</h3>
          <p class="mt-1 text-xs text-foreground/50 italic">Built a full-stack rental management system with a Spring Boot REST API,
Dockerised backend deployment, and a separately deployed frontend.</p>
          <!--<p class="mt-1 text-sm text-foreground/80">
            Full-stack rental management platform handling booking and inventory workflows.
          </p> -->
          <p class="mt-2 text-xs text-foreground/60">Java · Spring Boot · REST APIs · Docker · Render · Vercel</p>
          <div class="mt-3 flex gap-3">
            <a
              href="https://surfboard-rental-management.vercel.app"
              class="text-sm text-accent hover:underline"
            >View Project →</a>
            <a
              href="https://github.com/zxl3011/surfboard-rental-management"
              class="text-sm text-accent hover:underline"
            >GitHub →</a>
          </div>
        </li>
        <li class="border border-border rounded-lg p-4">
          <h3 class="text-lg font-semibold">Workforce Time Management System</h3>
          <p class="mt-1 text-xs text-foreground/50 italic">Developed backend APIs for staff administration and salary history, and
  collaborated on database-backend configuration features for standard hours,
  overtime rules, penalty settings, and role data.</p>
          <!--<p class="mt-1 text-sm text-foreground/80">
            Backend system for workforce records, reporting, and workflow approvals.
          </p> -->
          <p class="mt-2 text-xs text-foreground/60">Java · Spring Boot · MySQL · REST APIs · Azure DevOps</p>
          <div class="mt-3 flex gap-3">
            <span class="text-sm text-foreground/40">Team project · Code not public</span>
          </div>
        </li>

        <li class="border border-border rounded-lg p-4">
          <h3 class="text-lg font-semibold">Indigenous Art Atlas</h3>
          <p class="mt-1 text-xs text-foreground/50 italic">Integrated Leaflet.js with a server-side PHP/MySQL backend to serve geo-tagged artwork data with access-controlled views.</p>
          <!--<p class="mt-1 text-sm text-foreground/80">
            Interactive map platform for Indigenous artworks with role-based access control.
          </p> -->
          <p class="mt-2 text-xs text-foreground/60">PHP · MySQL · JavaScript · Leaflet.js</p>
          <div class="mt-3 flex gap-3">
            <a
              href="https://indigenous-art-atlas.onrender.com"
              class="text-sm text-accent hover:underline"
            >View Project →</a>
          </div>
        </li>
      </ul>
    </section>

    <section id="skills" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Skills</h2>
      <ul class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3">
        {
          [
            "Java",
            "JavaScript / TypeScript",
            "React",
            "Node.js / Express",
            "MongoDB / MySQL",
            "Spring Boot",
            "Git / GitHub",
          ].map(skill => (
            <li class="rounded border border-border px-3 py-2 text-sm font-medium text-center">
              {skill}
            </li>
          ))
        }
      </ul>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/projects">
        All Projects
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
